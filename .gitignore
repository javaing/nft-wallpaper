# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# Claude memory
.claude/

# logs & scripts
*.log
*.ps1

# typescript
*.tsbuildinfo

# generated native folders
/ios
# android 有自訂原生模組，不排除（由 android/.gitignore 過濾 build 產物）
